<Window x:Class="WpfNastolSystem.Windows.SessionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание чека — выбор сессии" Height="580" Width="780"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Завершённые неоплаченные сессии" 
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <DataGrid x:Name="dgSessions" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                  MouseDoubleClick="dgSessions_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding session_id}" Width="70"/>
                <!-- Исправлено: теперь привязка к game_titles -->
                <DataGridTextColumn Header="Игра" Binding="{Binding game_titles}" Width="*"/>
                <DataGridTextColumn Header="Стол" Binding="{Binding table_number}" Width="90"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding started_at, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Окончание" Binding="{Binding ended_at, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding cost, StringFormat=N0}" Width="90"/>
                <DataGridTextColumn Header="Организатор" Binding="{Binding organizer_name}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0" >
            <Button Content="Создать чек" Width="145" Margin="0,0,12,0" 
                    Click="BtnCreateCheck_Click" Style="{StaticResource CustomBlueButtonStyle}" Height="49"/>
            <Button Content="Отмена" Width="133" Click="BtnCancel_Click" Style="{StaticResource CustomBlueButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>