<Window x:Class="WpfNastolSystem.Windows.IncomingGameCopiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт по поступлениям"
        Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верх -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">

            <TextBlock Text="Отчёт по поступлениям"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0"/>

            <DatePicker x:Name="dpDate"
                        Width="180"
                        Margin="20,0,0,0"
                        Style="{StaticResource ModernDatePickerStyle}"/>

            <Button Content="Загрузить"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="BtnLoad_Click"
                    Style="{StaticResource CustomBlueButtonStyle}"/>
        </StackPanel>

        <!-- Таблица -->
        <DataGrid x:Name="dgItems"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Игра" Binding="{Binding GameTitle}" Width="*"/>
                <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="160"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding AcquiredDate}" Width="150"/>
                <DataGridTextColumn Header="Место" Binding="{Binding Location}" Width="150"/>
                <DataGridTextColumn Header="Состояние" Binding="{Binding Conditions}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="Сформировать PDF"
                    Width="200"
                    Click="BtnPrint_Click"
                    Style="{StaticResource CustomBlueButtonStyle}" Height="55"/>

            <Button Content="Закрыть"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="BtnCancel_Click"
                    Style="{StaticResource CustomBlueButtonStyle}"/>
        </StackPanel>

    </Grid>
</Window>