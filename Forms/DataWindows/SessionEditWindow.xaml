<Window x:Class="WpfNastolSystem.Forms.Edit.SessionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Редактирование сессии"
        Height="1071" 
    Width="629"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#EEF6FF">
    <Window.Resources>
        <!-- Если нужно — можно добавить локальные стили, но здесь используем существующие -->
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="tbTitle"
                   Text="Добавление сессии"
                   Style="{StaticResource PageTitleStyle}"
                   Margin="0,0,0,24"/>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Организатор -->
                <TextBlock Text="Организатор / Гейм-мастер *"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextBlueDark}"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="cmbOrganizer"
                  Style="{StaticResource FilterComboBoxStyle}"
                  Height="48"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  Margin="0,0,0,16"/>

                <!-- Стол -->
                <TextBlock Text="Стол *"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextBlueDark}"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="cmbTable"
          Style="{StaticResource FilterComboBoxStyle}"
          Height="48"
          DisplayMemberPath="DisplayText"
          SelectedValuePath="table_id"
          TextSearch.TextPath="DisplayText"
          Margin="0,0,0,16"/>

                <!-- Дата начала -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintStartDate"
                               Text="Дата начала"
                               Style="{StaticResource FloatingHintTextBoxStyle}">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="StartDateTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <DatePicker x:Name="dpStartDate"
                                Style="{StaticResource ModernDatePickerStyle}"
                                Margin="0,0,0,10"/>
                </Grid>

                <!-- Время начала -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintStartTime"
                               Text="Время начала (HH:MM)"
                               Style="{StaticResource FloatingHintTextBoxStyle}">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="StartTimeTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal"
                                Margin="16,18,0,10">
                        <TextBox x:Name="tbStartHour"
                                 Width="29"
                                 MaxLength="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15" Height="26"/>
                        <TextBlock Text=":"
                                   Margin="4,0"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="tbStartMinute"
                                 Width="31"
                                 MaxLength="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15" Height="28"/>
                    </StackPanel>
                </Grid>

                <!-- Активная сессия -->
                <CheckBox x:Name="chkActiveSession"
                          Content="Сессия ещё идёт"
                          Margin="0,4,0,16"
                          FontSize="14"
                          Foreground="{StaticResource TextBlueDark}"
                          IsChecked="True"
                          Checked="chkActiveSession_CheckedChanged"
                          Unchecked="chkActiveSession_CheckedChanged"/>

                <!-- Конец сессии -->
                <Grid x:Name="gridEndTime"
                      Margin="0,0,0,16"
                      IsEnabled="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="62"/>
                        <RowDefinition Height="62"/>
                    </Grid.RowDefinitions>

                    <!-- Дата окончания -->
                    <Grid>
                        <Border Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintEndDate"
                                   Text="Дата окончания"
                                   Style="{StaticResource FloatingHintTextBoxStyle}">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="EndDateTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <DatePicker x:Name="dpEndDate"
                                    Text =""
                                    Style="{StaticResource ModernDatePickerStyle}"
                                    Margin="0,0,0,10"/>
                    </Grid>

                    <!-- Время окончания -->
                    <Grid Grid.Row="1">
                        <Border Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintEndTime"
                                   Text="Время окончания (HH:MM)"
                                   Style="{StaticResource FloatingHintTextBoxStyle}">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="EndTimeTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal"
                                    Margin="16,18,0,10">
                            <TextBox x:Name="tbEndHour"
                                     Width="40"
                                     MaxLength="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="15"/>
                            <TextBlock Text=":"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="tbEndMinute"
                                     Width="40"
                                     MaxLength="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="15"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Участники -->
                <TextBlock Text="Участники"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextBlueDark}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <ComboBox x:Name="cmbAddParticipant"
              Style="{StaticResource FilterComboBoxStyle}"
              Width="320"
              Height="48"
              DisplayMemberPath="Name"
              SelectedValuePath="Id"
              IsEditable="False"/>
                    <Button Content="+"
                            Width="48"
                            Height="48"
                            Margin="8,0,0,0"
                            Style="{StaticResource CustomBlueButtonStyle}"
                            Click="btnAddParticipant_Click"/>
                </StackPanel>
                <ListView x:Name="lvParticipants"
                          Height="160"
                          Margin="0,0,0,16">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя"
                                            Width="220"
                                            DisplayMemberBinding="{Binding FullName}"/>
                            <GridViewColumn Header="Время"
                                            Width="80"
                                            DisplayMemberBinding="{Binding AddedAt}"/>
                            <GridViewColumn Header=""
                                            Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✖"
                                                Width="32"
                                                Height="32"
                                                Click="btnRemoveParticipant_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Стоимость (ввод вручную) -->

                <!-- Рассчитанная стоимость автоматически -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintCalculatedCost"
                               Text="Рассчитано автоматически"
                               Style="{StaticResource FloatingHintTextBoxStyle}"
                               IsHitTestVisible="False" Margin="366,0,0,0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="CalculatedCostTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="tbCalculatedCost"
                               Padding="16,20,16,0"
                               FontSize="15"
                               Foreground="#555"
                               Background="Transparent"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Text="—"/>
                </Grid>

                <!-- Оплачено -->
                <CheckBox x:Name="chkPaid"
                          Content="Оплачено"
                          Margin="0,4,0,16"
                          FontSize="14"
                          Foreground="{StaticResource TextBlueDark}"/>

                <!-- Примечания -->
                <Grid Height="100" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintNotes"
                               Text="Примечания"
                               Style="{StaticResource FloatingHintTextBoxStyle}"
                               VerticalAlignment="Top"
                               Margin="0,6,0,0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="NotesTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="tbNotes"
                             Padding="16,20,16,8"
                             FontSize="15"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Сохранить"
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#28a745"
                    BorderBrush="#28a745"
                    Width="140"
                    Height="48"
                    Margin="0,0,12,0"
                    Click="btnSave_Click"/>
            <Button Content="Отмена"
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#6c757d"
                    BorderBrush="#6c757d"
                    Width="140"
                    Height="48"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>