<Window x:Class="WpfNastolSystem.Forms.Edit.PersonEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя"
        Height="650" Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#EEF6FF">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Добавление пользователя" 
                   Style="{StaticResource PageTitleStyle}" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ФИО -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintFullName" Text="ФИО *" 
                               Style="{StaticResource FloatingHintTextBoxStyle}" IsHitTestVisible="False">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="FullNameTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="FullNameTextBox"
                             Padding="16,12,16,0" FontSize="15" Background="Transparent"
                             BorderThickness="0" VerticalContentAlignment="Bottom"
                             CaretBrush="{StaticResource PrimaryBlue}" MaxLength="150" Margin="0,0,0,10"/>
                </Grid>

                <!-- Телефон -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintPhone" Text="Телефон *" 
                               Style="{StaticResource FloatingHintTextBoxStyle}" IsHitTestVisible="False">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="PhoneTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="PhoneTextBox"
                             Padding="16,12,16,0" FontSize="15" Background="Transparent"
                             BorderThickness="0" VerticalContentAlignment="Bottom"
                             CaretBrush="{StaticResource PrimaryBlue}" MaxLength="20" Height="52" VerticalAlignment="Top"/>
                </Grid>

                <!-- Email -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintEmail" Text="Email *" 
                               Style="{StaticResource FloatingHintTextBoxStyle}" IsHitTestVisible="False">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="EmailTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="EmailTextBox"
                             Padding="16,12,16,0" FontSize="15" Background="Transparent"
                             BorderThickness="0" VerticalContentAlignment="Bottom"
                             CaretBrush="{StaticResource PrimaryBlue}" MaxLength="120" Margin="0,0,0,9"/>
                </Grid>
                <TextBlock Text="Дата рождения *"
           FontSize="14"
           FontWeight="Medium"
           Foreground="{StaticResource TextBlueDark}"
           Margin="0,0,0,8"/>

                <Grid Height="62" Margin="0,0,0,16">

                    <Border Style="{StaticResource InputBorderStyle}"/>

                    <DatePicker x:Name="BirthDatePicker"
                Background="Transparent"
                BorderThickness="0"
                FontSize="15"
                Padding="16,12,16,0"
                VerticalContentAlignment="Center"
                Margin="0,0,0,10"/>

                </Grid>

                <!-- Статус блокировки -->
                <CheckBox x:Name="IsBannedCheckBox" Content="Заблокирован"
                          Margin="0,4,0,20" FontSize="14" Foreground="{StaticResource TextBlueDark}"/>

                <!-- Примечания -->
                <Grid Height="100" Margin="0,0,0,16">
                    <Border Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintNotes" Text="Примечание" 
                               Style="{StaticResource FloatingHintTextBoxStyle}" IsHitTestVisible="False" Height="48" Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="NotesTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="NotesTextBox"
                             Padding="16,20,16,8" FontSize="15" Background="Transparent"
                             BorderThickness="0" VerticalContentAlignment="Top" TextWrapping="Wrap"
                             AcceptsReturn="True" MaxLength="500" CaretBrush="{StaticResource PrimaryBlue}"/>
                </Grid>

                <!-- Информация о регистрации (только для редактирования) -->
                <Grid x:Name="InfoGrid" Visibility="Collapsed" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата регистрации:" 
                               Foreground="#2C3E50" FontSize="13"/>
                    <TextBlock x:Name="RegisteredAtText" Grid.Row="0" Grid.Column="1"
                               Foreground="#2C3E50" FontSize="13"/>
                </Grid>

                <TextBlock Text="* - обязательные поля" FontSize="11" Foreground="#888888" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SaveButton" Content="Сохранить"
                    Style="{StaticResource CustomBlueButtonStyle}" Background="#28a745" BorderBrush="#28a745"
                    Width="140" Height="48" Margin="0,0,12,0" IsEnabled="False" Click="SaveButton_Click"/>
            <Button Content="Отмена" Style="{StaticResource CustomBlueButtonStyle}" Background="#6c757d"
                    BorderBrush="#6c757d" Width="140" Height="48" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>