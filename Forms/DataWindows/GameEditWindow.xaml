<Window x:Class="WpfNastolSystem.Forms.Edit.GameEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование игры"
        Height="650"
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#EEF6FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" 
                   Text="Добавление игры"
                   Style="{StaticResource PageTitleStyle}"
                   Margin="0,0,0,20"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                <TextBox x:Name="TitleTextBox" 
                         Style="{StaticResource SearchTextBoxStyle}"
                         Height="40"
                         Margin="0,0,0,15"/>
                <TextBlock Text="Описание" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                <TextBox x:Name="DescriptionTextBox" 
                         Style="{StaticResource SearchTextBoxStyle}"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Год выпуска" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="YearTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Издатель" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="PublisherTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Категория" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                <ComboBox x:Name="CategoryComboBox" 
                          Style="{StaticResource FilterComboBoxStyle}"
                          Height="40"
                          Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Мин. игроков" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="MinPlayersTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Макс. игроков" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="MaxPlayersTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Время игры (мин)" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="PlayTimeTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Возрастной рейтинг" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                        <TextBox x:Name="AgeRatingTextBox" 
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Height="40"
                                 Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Рейтинг BGG" Margin="0,0,0,5" Foreground="{StaticResource TextBlueDark}"/>
                <TextBox x:Name="BggRatingTextBox" 
                         Style="{StaticResource SearchTextBoxStyle}"
                         Height="40"
                         Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#28a745"
                    BorderBrush="#28a745"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена" 
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#6c757d"
                    BorderBrush="#6c757d"
                    Width="120"
                    Height="40"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>