<Window x:Class="WpfNastolSystem.Forms.Edit.GameEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление игры"
        Height="680"
        Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#EEF6FF">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleText"
                   Text="Добавление игры"
                   Style="{StaticResource PageTitleStyle}"
                   Margin="0,0,0,24"/>

        <!-- Основной контент со скроллом -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Название -->
                <Grid Height="62" Margin="0,0,0,16">
                    <Border x:Name="TitleBorder" Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintTitle"
                               Text="Название игры"
                               Style="{StaticResource FloatingHintTextBoxStyle}"
                               IsHitTestVisible="False" Height="42">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="TitleTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="TitleTextBox"
                             Padding="16,12,16,0"
                             FontSize="15"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Bottom"
                             CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                </Grid>

                <!-- Описание -->
                <Grid Height="99" Margin="0,0,0,18">
                    <Border x:Name="DescriptionBorder" Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintDescription"
                               Text="Описание"
                               Style="{StaticResource FloatingHintTextBoxStyle}"
                               IsHitTestVisible="False" Margin="0,6,0,0" VerticalAlignment="Top">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="DescriptionTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="DescriptionTextBox"
                             Padding="16,20,16,8"
                             FontSize="15"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                </Grid>

                <!-- Год + Издатель -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Год -->
                    <Grid Grid.Column="0" Height="62">
                        <Border x:Name="YearBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintYear"
                                   Text="Год выпуска"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="YearTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="YearTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                    </Grid>

                    <!-- Издатель -->
                    <Grid Grid.Column="2" Height="62">
                        <Border x:Name="PublisherBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintPublisher"
                                   Text="Издатель"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="PublisherTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="PublisherTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                    </Grid>
                </Grid>

                <!-- Категория -->
                <TextBlock Text="Категория" 
                           FontSize="14" 
                           FontWeight="Medium"
                           Foreground="{StaticResource TextBlueDark}"
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="CategoryComboBox"
                          Style="{StaticResource FilterComboBoxStyle}"
                          Height="48"
                          Margin="0,0,0,16"/>

                <!-- Мин / Макс игроки -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Height="62">
                        <Border x:Name="MinPlayersBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintMinPlayers"
                                   Text="Мин. игроков"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="MinPlayersTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="MinPlayersTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                    </Grid>

                    <Grid Grid.Column="2" Height="62">
                        <Border x:Name="MaxPlayersBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintMaxPlayers"
                                   Text="Макс. игроков"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="MaxPlayersTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="MaxPlayersTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,9"/>
                    </Grid>
                </Grid>

                <!-- Время игры + Возраст -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Height="62">
                        <Border x:Name="PlayTimeBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintPlayTime"
                                   Text="Время игры (мин)"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="PlayTimeTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="PlayTimeTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                    </Grid>

                    <Grid Grid.Column="2" Height="62">
                        <Border x:Name="AgeRatingBorder" Style="{StaticResource InputBorderStyle}"/>
                        <TextBlock x:Name="HintAgeRating"
                                   Text="Возрастной рейтинг"
                                   Style="{StaticResource FloatingHintTextBoxStyle}"
                                   IsHitTestVisible="False">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="AgeRatingTransform"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBox x:Name="AgeRatingTextBox"
                                 Padding="16,12,16,0"
                                 FontSize="15"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Bottom"
                                 CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                    </Grid>
                </Grid>

                <!-- Рейтинг BGG -->
                <Grid Height="62" Margin="0,0,0,24">
                    <Border x:Name="BggRatingBorder" Style="{StaticResource InputBorderStyle}"/>
                    <TextBlock x:Name="HintBggRating"
                               Text="Рейтинг BGG (0–10)"
                               Style="{StaticResource FloatingHintTextBoxStyle}"
                               IsHitTestVisible="False">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="BggRatingTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBox x:Name="BggRatingTextBox"
                             Padding="16,12,16,0"
                             FontSize="15"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Bottom"
                             CaretBrush="{StaticResource PrimaryBlue}" Margin="0,0,0,9"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Сохранить"
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#28a745"
                    BorderBrush="#28a745"
                    Width="140"
                    Height="48"
                    Margin="0,0,12,0"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена"
                    Style="{StaticResource CustomBlueButtonStyle}"
                    Background="#6c757d"
                    BorderBrush="#6c757d"
                    Width="140"
                    Height="48"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>